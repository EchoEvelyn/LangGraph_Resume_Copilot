# LLM Provider (swap as needed)
OPENAI_API_KEY=sk_..
# Model settings
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# Storage
DB_PATH=./data/results.db

# LangSmith Tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-..
LANGCHAIN_PROJECT=langgraph-resume-copilot
